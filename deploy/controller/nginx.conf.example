# Place inside the http context after obtaining a TLS certificate.
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name api.replaybook.dev;

    ssl_certificate /etc/letsencrypt/live/api.replaybook.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.replaybook.dev/privkey.pem;

    client_max_body_size 16k;
    proxy_connect_timeout 5s;
    proxy_read_timeout 30s;
    proxy_send_timeout 30s;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

